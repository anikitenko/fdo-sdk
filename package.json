{
  "name": "@anikitenko/fdo-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/anikitenko/fdo-sdk.git"
  },
  "version": "1.0.22",
  "description": "SDK for FlexDevOPs (FDO) application modules",
  "keywords": [
    "fdo",
    "flex",
    "devops",
    "flexdevops",
    "sdk",
    "fdo-sdk",
    "plugin",
    "plugin-framework",
    "electron",
    "desktop-app",
    "dom-builder",
    "typescript"
  ],
  "author": "anikitenko",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "homepage": "https://plugins.fdo.alexvwan.me",
  "bugs": {
    "url": "https://github.com/anikitenko/fdo-sdk/issues"
  },
  "main": "dist/fdo-sdk.bundle.js",
  "types": "dist/@types/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/@types/index.d.ts",
      "require": "./dist/fdo-sdk.bundle.js",
      "default": "./dist/fdo-sdk.bundle.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.json",
    "examples"
  ],
  "scripts": {
    "build": "webpack --config webpack.config.cjs",
    "build:types": "tsc --emitDeclarationOnly",
    "test:examples": "tsc --project examples/tsconfig.json --noEmit",
    "verify:pack": "node scripts/verify-pack-dry-run.mjs",
    "prebuild": "npm run build:types",
    "prepack": "npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "coverage:open": "npx opn coverage/lcov-report/index.html || true",
    "prepublishOnly": "npm test && npm run test:examples && npm run build"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@types/jest": "^29.5.14",
    "@types/write-file-atomic": "^4.0.3",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-morph": "^25.0.1",
    "typescript": "^5.7.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-sources": "^3.2.3"
  },
  "dependencies": {
    "@expo/sudo-prompt": "github:expo/sudo-prompt",
    "electron": "^35.0.0",
    "goober": "^2.1.16",
    "pify": "^6.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "write-file-atomic": "^6.0.0"
  }
}
