{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FDO SDK",
  "description": "SDK for building FlexDevOps desktop application plugins.",
  "colors": {
    "primary": "#2563EB"
  },
  "appearance": {
    "default": "system",
    "strict": false
