            "pages": [
              "guides/runtime-model",
              "docs/ARCHITECTURE",
              "docs/RENDER_RUNTIME_CONTRACT",
              "docs/SAFE_PLUGIN_AUTHORING",
              "docs/EXTENSION_POINTS",
              "docs/API_STABILITY"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "docs/QUICK_REFERENCE",
              "docs/INJECTED_LIBRARIES",
              "docs/HOST_PRIVILEGED_ACTIONS_CONTRACT",
              "docs/SHAREPOINT_PROVIDER_HOST_CONTRACT"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "docs/EXAMPLES_AND_FIXTURES"
